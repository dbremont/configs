[core]
	autocrlf = input
	editor = nvim
	hooksPath = ~/configs/global/git/hooks
[commit]
	status= false
[gpg]
	format = ssh
[gpg "ssh"]
	program = /opt/1Password/op-ssh-sign
	allowedSignersFile = ~/configs/local/allowed_signers
[commit]
	gpgsign = true
[user]
	email = darlynvictoriano@gmail.com
[http]
	postBuffer = 524288000
	maxRequestBuffer = 1048576000
[merge]
	tool = vimdiff
[init]
	defaultBranch = main
